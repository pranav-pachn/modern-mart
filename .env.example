# ============================================
# SUPERMARKET E-COMMERCE - ENVIRONMENT VARIABLES
# ============================================

# --------------------------------------------
# BACKEND VARIABLES (backend/.env.local)
# --------------------------------------------

# MongoDB (Required)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>/<database>?retryWrites=true&w=majority

# Admin Secret for API access (Required for admin routes)
ADMIN_SECRET=your_admin_secret_here

# AI Providers (at least one required for AI features)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OR
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Razorpay (Optional - for online payments)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx

# --------------------------------------------
# FRONTEND VARIABLES (frontend/apps/web/.env.local)
# --------------------------------------------

# Backend API URL (Required - must match deployed backend URL in production)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Auth.js / NextAuth (Required)
# Use same AUTH_SECRET in both backend and frontend
AUTH_SECRET=your_random_secret_key_here
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (Optional - for social login)
GOOGLE_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx

# ⚠️ DEV ONLY: Admin secret for local API scripting (NOT for production!)
# In production, admin auth uses NextAuth JWT cookies, not this secret
NEXT_PUBLIC_ADMIN_SECRET=your_dev_admin_secret

# Razorpay Frontend Key (Optional)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx

# ============================================
# ⚠️ IMPORTANT DEPLOYMENT NOTES
# ============================================
# 1. Backend and Frontend MUST be deployed as separate Vercel projects
# 2. Frontend API calls use NEXT_PUBLIC_API_URL + "/api/..."
# 3. NEXT_PUBLIC_ADMIN_SECRET is for LOCAL DEV ONLY - never use in production!
# 4. In production, admin routes are protected by NextAuth JWT (role=admin)
