# MongoDB
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>/<database>?retryWrites=true&w=majority

# Razorpay
ENABLE_ONLINE_PAYMENTS=false
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx

# AI providers (single key or comma-separated keys)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Frontend public key
NEXT_PUBLIC_ENABLE_ONLINE_PAYMENTS=false
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx

# Auth.js / NextAuth
AUTH_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AUTH_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx

# Frontend API routing overrides (optional)
PRODUCTS_API_URL=http://localhost:3001/api/products
ORDERS_API_URL=http://localhost:3001/api/orders
HEALTH_API_URL=http://localhost:3001/api/health/db
PAYMENT_API_URL=http://localhost:3001/api/payment
AI_API_URL=http://localhost:3001/api/ai
