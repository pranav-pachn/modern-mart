# ============================================
# FRONTEND ENVIRONMENT VARIABLES
# Copy this file to .env.local for local development
# For Vercel deployment: Set these in Project Settings → Environment Variables
# ============================================

# --------------------------------------------
# REQUIRED
# --------------------------------------------

# MongoDB Connection String
# Server-only: required by Auth.js, registration, user addresses, orders, and AI history.
# Do NOT prefix this with NEXT_PUBLIC_.
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority

# NextAuth Configuration
# Use either AUTH_SECRET or NEXTAUTH_SECRET for server-side auth checks
NEXTAUTH_SECRET=your_random_secret_key_here

# Your frontend URL (for NextAuth callbacks)
# Local: http://localhost:3000
# Production: https://your-frontend.vercel.app
NEXTAUTH_URL=http://localhost:3000

# --------------------------------------------
# OPTIONAL (for Google OAuth login)
# --------------------------------------------

# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx

# --------------------------------------------
# OPTIONAL (for AI providers)
# OPENROUTER_API_KEY=your_openrouter_key
# GROQ_API_KEY=your_groq_key

# OPTIONAL (for online payments)
# --------------------------------------------

# Razorpay Public Key (test mode)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx

# --------------------------------------------
# NOTES FOR VERCEL DEPLOYMENT
# --------------------------------------------
# 1. Create a single Vercel project with Root Directory set to: frontend/apps/web
# 2. Add MONGODB_URI and NEXTAUTH_SECRET in Project Settings → Environment Variables
# 3. Add optional AI/payment env vars only if you use those features
