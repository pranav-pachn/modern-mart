# ============================================
# FRONTEND ENVIRONMENT VARIABLES
# Copy this file to .env.local for local development
# For Vercel deployment: Set these in Project Settings → Environment Variables
# ============================================

# --------------------------------------------
# REQUIRED
# --------------------------------------------

# Backend API URL - Frontend calls this for all API requests
# Local: http://localhost:3001
# Production: https://your-backend.vercel.app (deploy backend first!)
NEXT_PUBLIC_API_URL=http://localhost:3001

# MongoDB Connection String
# Server-only: required by Auth.js, registration, user addresses, orders, and AI history.
# Do NOT prefix this with NEXT_PUBLIC_.
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority

# NextAuth Configuration
# MUST match the AUTH_SECRET in backend
AUTH_SECRET=your_random_secret_key_here

# Your frontend URL (for NextAuth callbacks)
# Local: http://localhost:3000
# Production: https://your-frontend.vercel.app
NEXTAUTH_URL=http://localhost:3000

# --------------------------------------------
# OPTIONAL (for Google OAuth login)
# --------------------------------------------

# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx

# --------------------------------------------
# OPTIONAL (for online payments)
# --------------------------------------------

# Razorpay Public Key (test mode)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx

# --------------------------------------------
# NOTES FOR VERCEL DEPLOYMENT
# --------------------------------------------
# 1. Deploy backend FIRST and get its URL
# 2. Create new Vercel project for frontend
# 3. Set Root Directory to: frontend/apps/web
# 4. Set NEXT_PUBLIC_API_URL to your deployed backend URL
# 5. Set AUTH_SECRET to match backend's AUTH_SECRET
# 6. Frontend calls backend APIs - no MongoDB needed in frontend
