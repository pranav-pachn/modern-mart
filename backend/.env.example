# ============================================
# BACKEND ENVIRONMENT VARIABLES
# Copy this file to .env.local for local development
# For Vercel deployment: Set these in Project Settings → Environment Variables
# ============================================

# --------------------------------------------
# REQUIRED
# --------------------------------------------

# MongoDB Connection String
# Get from MongoDB Atlas: https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority

# NextAuth JWT Secret (generate with: openssl rand -base64 32)
# MUST match the AUTH_SECRET in frontend
AUTH_SECRET=your_random_secret_key_here

# Admin Secret for API access (for local dev scripting only)
# In production, admin auth uses NextAuth JWT with role=admin
ADMIN_SECRET=your_admin_secret_here

# --------------------------------------------
# OPTIONAL (for AI features)
# --------------------------------------------

# AI Provider API Keys (at least one required for AI recipe features)
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OR get from: https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --------------------------------------------
# OPTIONAL (for online payments)
# --------------------------------------------

# Razorpay Credentials
# Get from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx

# --------------------------------------------
# NOTES FOR VERCEL DEPLOYMENT
# --------------------------------------------
# 1. Deploy backend as separate Vercel project
# 2. Set Root Directory to: backend
# 3. Add all variables above to Vercel Dashboard
# 4. Get deployed URL (e.g., https://api-supermart.vercel.app)
# 5. Use that URL as NEXT_PUBLIC_API_URL in frontend
